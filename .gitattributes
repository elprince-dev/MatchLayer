# Normalize line endings on commit. WSL/Linux runs the toolchain
# (uv, pytest, pnpm, dos2unix-sensitive shells), so LF is the canonical
# format for all text files in the repo. Windows checkouts get LF too;
# editors that insist on CRLF should be configured per developer.

* text=auto eol=lf

# Config and shell scripts must be LF — pydantic-settings reads `.env*`
# verbatim and a stray \r will end up appended to the parsed value.
*.env       text eol=lf
.env.*      text eol=lf
*.sh        text eol=lf

# Source files
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sql       text eol=lf
*.css       text eol=lf
*.html      text eol=lf

# Lock files — let the package manager decide.
pnpm-lock.yaml  text eol=lf
uv.lock         text eol=lf

# Binary files — never normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
