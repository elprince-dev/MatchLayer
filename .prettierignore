# Root Prettier ignore list.
#
# These files are GENERATED artifacts whose canonical formatter is NOT
# Prettier. Running Prettier over them produces a diff on every regeneration,
# which fights the byte-identical drift checks that gate the build. Keep them
# out of `prettier --check .` / `prettier --write .` (the root `pnpm format`
# and `pnpm format:write` scripts).
#
# Note: CI does not run the root format script — the frontend and shared-types
# jobs run package-scoped `pnpm --filter ... format`, and the pre-commit hook
# carries its own matching `exclude` list. This file protects developers who
# run `pnpm format:write` from the repo root.

# Lockfile (machine-generated, anchor-heavy).
pnpm-lock.yaml

# OpenAPI codegen output (also pinned in packages/shared-types/.prettierignore,
# which scopes the package-level format script).
packages/shared-types/src/api-types.ts
packages/shared-types/src/api-schemas.ts

