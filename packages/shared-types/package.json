{
  "name": "@matchlayer/shared-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MatchLayer shared TypeScript types and Zod schemas, generated from the FastAPI OpenAPI spec.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "prettier --check 'src/**/*.{ts,json,md}' 'scripts/**/*.mjs'",
    "codegen": "node ./scripts/codegen.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@zodios/core": "^10.9.6",
    "axios": "^1.7.9",
    "eslint": "^9.18.0",
    "execa": "^9.5.2",
    "globals": "^15.14.0",
    "openapi-typescript": "^7.4.4",
    "openapi-zod-client": "^1.18.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.0",
    "zod": "^3.25.76"
  }
}
