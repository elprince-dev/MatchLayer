# MatchLayer — example environment file
#
# Copy this file to `.env` at the repo root:
#   cp .env.example .env
#
# The defaults below are wired to the local docker-compose stack
# (Postgres, Redis, MinIO) so a fresh checkout can run both apps with
# no further edits. Real secrets must NEVER be committed here — `.env`
# is gitignored, this file is the committed sample.
#
# Variable contract is defined in
# `.kiro/specs/phase-1-foundation/design.md` §12.

# ---------------------------------------------------------------------------
# Backend (apps/api) — read by `matchlayer_api.config.Settings`
# ---------------------------------------------------------------------------

# Runtime environment. Drives logging format (console in development,
# JSON otherwise) and other env-conditional behavior.
# One of: development | staging | production
MATCHLAYER_ENVIRONMENT=development

# Log level for structlog. One of: debug | info | warning | error
MATCHLAYER_LOG_LEVEL=info

# Postgres async DSN. Must use the `postgresql+asyncpg://` driver form —
# Alembic swaps it to `+psycopg` internally for sync migrations.
# Matches the docker-compose `postgres` service defaults.
MATCHLAYER_DATABASE_URL=postgresql+asyncpg://matchlayer:dev_only_password@localhost:5432/matchlayer

# Redis DSN, including database index. Matches the docker-compose `redis` service.
MATCHLAYER_REDIS_URL=redis://localhost:6379/0

# S3 / MinIO configuration.
# In local dev this points at the MinIO container; in production this is left
# empty / unset so boto3 talks to real AWS S3 directly.
MATCHLAYER_S3_ENDPOINT_URL=http://localhost:9000
MATCHLAYER_S3_REGION=us-east-1
MATCHLAYER_S3_ACCESS_KEY_ID=matchlayer
MATCHLAYER_S3_SECRET_ACCESS_KEY=dev_only_password

# S3 bucket name. Created manually in MinIO via `mc mb` for local dev
# (auto-bootstrap arrives in `phase-1-matching`).
MATCHLAYER_S3_BUCKET=matchlayer-dev

# Comma-separated list of allowed CORS origins for the API.
# Local dev only needs the Next.js dev server.
MATCHLAYER_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Authentication (apps/api) — JWT, rate limiting, lockout.
# Defined by the phase-1-auth design §17.1.
# ---------------------------------------------------------------------------

# JWT signing secret. MUST be >= 32 bytes UTF-8.
# The API refuses to start if this constraint is violated (config.py
# Settings._jwt_secret_min_length validator). Generate a real one for
# staging/prod with: python -c "import secrets; print(secrets.token_urlsafe(48))"
MATCHLAYER_JWT_SECRET=change-me-development-only-32+chars

# Token TTLs (seconds). Access = 15 min, Refresh = 7 days.
MATCHLAYER_AUTH_ACCESS_TOKEN_TTL_SECONDS=900
MATCHLAYER_AUTH_REFRESH_TOKEN_TTL_SECONDS=604800

# Account lockout: lock after N failed logins inside WINDOW seconds,
# stay locked for DURATION seconds.
MATCHLAYER_AUTH_LOCKOUT_THRESHOLD=10
MATCHLAYER_AUTH_LOCKOUT_WINDOW_SECONDS=900
MATCHLAYER_AUTH_LOCKOUT_DURATION_SECONDS=900

# Base URL of the web app. Used to build dev-mode reset links.
MATCHLAYER_WEB_BASE_URL=http://localhost:3000

# Postgres role that the auth migration grants INSERT/SELECT on
# audit_events to. This is intentionally a least-privilege role
# distinct from the docker-compose ``POSTGRES_USER`` (which is the
# table owner and bypasses GRANT/REVOKE). The role is provisioned
# by ``infra/docker/postgres-init/01-create-app-role.sql`` on first
# boot of the data volume and re-asserted by the migration on every
# upgrade.
MATCHLAYER_DATABASE_APP_ROLE=matchlayer_app
# Password for ``MATCHLAYER_DATABASE_APP_ROLE``. Used by the
# integration test suite (audit_role_engine fixture, INV-1) and by
# any local tooling that connects as the app role. Dev-only; in
# production the role is provisioned by AWS Secrets Manager-backed
# bootstrap.
MATCHLAYER_DATABASE_APP_ROLE_PASSWORD=dev_only_app_role_password

# Rate-limit defaults per endpoint. Sliding-window via Redis SORTED SET.
MATCHLAYER_AUTH_RATE_LIMIT_REGISTER_IP_LIMIT=10
MATCHLAYER_AUTH_RATE_LIMIT_REGISTER_IP_WINDOW_SECONDS=900
MATCHLAYER_AUTH_RATE_LIMIT_LOGIN_EMAIL_LIMIT=10
MATCHLAYER_AUTH_RATE_LIMIT_LOGIN_EMAIL_WINDOW_SECONDS=900
MATCHLAYER_AUTH_RATE_LIMIT_LOGIN_IP_LIMIT=50
MATCHLAYER_AUTH_RATE_LIMIT_LOGIN_IP_WINDOW_SECONDS=900
MATCHLAYER_AUTH_RATE_LIMIT_REFRESH_IP_LIMIT=60
MATCHLAYER_AUTH_RATE_LIMIT_REFRESH_IP_WINDOW_SECONDS=60
MATCHLAYER_AUTH_RATE_LIMIT_RESET_REQUEST_EMAIL_LIMIT=5
MATCHLAYER_AUTH_RATE_LIMIT_RESET_REQUEST_EMAIL_WINDOW_SECONDS=3600
MATCHLAYER_AUTH_RATE_LIMIT_RESET_REQUEST_IP_LIMIT=20
MATCHLAYER_AUTH_RATE_LIMIT_RESET_REQUEST_IP_WINDOW_SECONDS=3600
MATCHLAYER_AUTH_RATE_LIMIT_RESET_CONFIRM_IP_LIMIT=20
MATCHLAYER_AUTH_RATE_LIMIT_RESET_CONFIRM_IP_WINDOW_SECONDS=3600

# ---------------------------------------------------------------------------
# Frontend (apps/web) — only `NEXT_PUBLIC_*` values are exposed to the browser
# ---------------------------------------------------------------------------

# Base URL the web app uses to reach the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
